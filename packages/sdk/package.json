{
  "name": "budabit-sdk",
  "version": "0.1.2",
  "description": "SDK for building Budabit Smart Widget extensions — types, bridge, manifest CLI, and test utilities",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./testing": {
      "types": "./dist/testing/index.d.ts",
      "import": "./dist/testing/index.js"
    },
    "./worker": {
      "types": "./dist/worker/index.d.ts",
      "import": "./dist/worker/index.js"
    },
    "./manifest": {
      "types": "./dist/manifest/index.d.ts",
      "import": "./dist/manifest/index.js"
    }
  },
  "bin": {
    "budabit-generate": "./dist/manifest/cli.js",
    "budabit-publish": "./dist/manifest/publish.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "keywords": [
    "budabit",
    "nostr",
    "smart-widget",
    "sdk",
    "kind-30033",
    "extension"
  ],
  "license": "MIT",
  "dependencies": {
    "commander": "^12.1.0",
    "nostr-tools": "^2.16.0",
    "zod": "^3.24.1"
  },
  "peerDependencies": {
    "vitest": ">=2.0.0"
  },
  "peerDependenciesMeta": {
    "vitest": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "jsdom": "^29.0.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
