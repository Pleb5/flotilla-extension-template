{
  "name": "my-flotilla-widget",
  "version": "0.1.0",
  "private": true,
  "description": "A Flotilla Smart Widget extension",
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter @my-widget/iframe dev",
    "build": "pnpm -r build",
    "test": "vitest run",
    "test:watch": "vitest",
    "e2e": "playwright test",
    "typecheck": "pnpm -r typecheck",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "clean": "pnpm -r clean && rm -rf node_modules",
    "manifest:generate": "flotilla-generate --title 'My Widget' --type tool --app-url '${WIDGET_APP_URL:-http://localhost:5173}' --icon 'Sparkles' --image 'https://example.com/preview.png' --identifier 'my-widget' --permissions 'nostr:publish,nostr:query,nostr:subscribe,ui:toast'"
  },
  "keywords": ["flotilla", "nostr", "smart-widget"],
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@playwright/test": "^1.48.2",
    "@types/node": "^22.10.2",
    "@vitest/coverage-v8": "^2.1.8",
    "eslint": "^9.17.0",
    "flotilla-sdk": "^0.1.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.1",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  }
}
