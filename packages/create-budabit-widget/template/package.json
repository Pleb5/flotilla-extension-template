{
  "name": "my-budabit-widget",
  "version": "0.1.0",
  "private": true,
  "description": "A BudaBit Smart Widget extension",
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter @my-widget/iframe dev",
    "build": "pnpm -r build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "e2e": "playwright test",
    "e2e:headed": "playwright test --headed",
    "e2e:debug": "playwright test --debug",
    "typecheck": "pnpm -r typecheck",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "clean": "pnpm -r clean && rm -rf node_modules",
    "verify": "pnpm lint && pnpm typecheck && pnpm test:coverage && pnpm e2e",
    "manifest:generate": "budabit-generate --title 'My Widget' --type tool --app-url '${WIDGET_APP_URL:-http://localhost:5173}' --icon 'Sparkles' --image 'https://example.com/preview.png' --identifier 'my-widget' --version '0.1.0' --changelog 'Initial release' --permissions 'nostr:publish,nostr:query,nostr:subscribe,ui:toast'",
    "manifest:publish": "budabit-publish",
    "widget:build": "pnpm build && pnpm manifest:generate",
    "widget:publish": "pnpm widget:build && pnpm manifest:publish",
    "widget:publish:dry-run": "pnpm widget:build && budabit-publish --dry-run",
    "widget:publish:blossom": "pnpm widget:build && budabit-publish --upload-first --blossom https://blossom.primal.net --artifact packages/iframe-app/dist/index.html",
    "widget:publish:github": "pnpm widget:build && budabit-publish --upload-first --github-repo ${GITHUB_REPO} --github-tag ${GITHUB_TAG} --artifact packages/iframe-app/dist/index.html"
  },
  "keywords": [
    "budabit",
    "nostr",
    "smart-widget",
    "kind-30033"
  ],
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@playwright/test": "^1.48.2",
    "@types/node": "^22.10.2",
    "@vitest/coverage-v8": "^2.1.8",
    "@vitest/ui": "^2.1.8",
    "budabit-sdk": "^0.1.0",
    "eslint": "^9.17.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.1",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@8.15.0"
}
